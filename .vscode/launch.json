{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python Debugger: Django",
      "type": "python",
      "request": "launch",
      "python": "${workspaceFolder}/.venv/bin/python",
      "program": "${workspaceFolder}/run/manage.py",
      "args": ["runserver", "8000"],
      "django": true,
      "env": {
        "DOPPLER_ENV": "1",
        "DOPPLER_PROJECT": "yo-momma",
        "DOPPLER_CONFIG": "dev"
      }
    }
  ]
}